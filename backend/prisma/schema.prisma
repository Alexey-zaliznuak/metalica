generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  SKETCH_DESIGNER
  REVISION_DESIGNER
  ADMIN
}

enum UserScope {
  ORDERS_CHANGE_RESPONSIBLE @map("orders.change_responsible")
  METRICS_VIEW              @map("metrics.view")
  WORKLOAD_VIEW             @map("workload.view")
}

enum OrderSource {
  MANUAL
  BLUESALES
}

enum OrderStatusChangeState {
  PENDING
  PROCESSING
  RETRY
  SUCCEEDED
}

enum ChatType {
  PUBLIC
  PRIVATE
}

enum ChatMemberRole {
  MEMBER
  MODERATOR
}

model User {
  id                       Int                 @id @default(autoincrement())
  username                 String              @unique
  name                     String
  role                     Role                @default(MANAGER)
  scopes                   UserScope[]         @default([])
  passwordHash             String
  frontendSettings         Json?
  messages                 Message[]
  chatMemberships          ChatMember[]
  chatMessages             ChatMessage[]
  createdChats             Chat[]              @relation("ChatCreatedBy")
  ordersAsSketchDesigner   Order[]             @relation("OrderSketchDesigner")
  ordersAsRevisionDesigner Order[]             @relation("OrderRevisionDesigner")
  // Правки, которые пользователь ЗАКРЫЛ (денормализованный closedById в RevisionClosure)
  closedRevisions          RevisionClosure[]   @relation("RevisionClosedBy")
  // События лога заказов, автором которых является пользователь
  orderEvents              OrderEvent[]        @relation("OrderEventActor")
  orderStatusChanges       OrderStatusChange[] @relation("OrderStatusChangeActor")
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  @@index([role])
}

model Order {
  id                    Int                 @id @default(autoincrement())
  orderNumber           String              @unique
  title                 String?
  source                OrderSource         @default(MANUAL)
  messages              Message[]
  revisions             Revision[]
  events                OrderEvent[]
  statusChanges         OrderStatusChange[]
  // Имена менеджеров подтягиваются из BlueSales (не FK):
  //  - deliveryManagerName  — менеджер ведения (customer.manager из BS)
  //  - onboardingManagerName — менеджер оформления (custom-поле «Оформление» из BS)
  deliveryManagerName   String?
  onboardingManagerName String?
  sketchDesigner        User?               @relation("OrderSketchDesigner", fields: [sketchDesignerId], references: [id])
  sketchDesignerId      Int?
  revisionDesigner      User?               @relation("OrderRevisionDesigner", fields: [revisionDesignerId], references: [id])
  revisionDesignerId    Int?
  // Замер времени эскиза по статусам заказа BlueSales:
  //  - sketchStartedAt — момент ПЕРВОГО входа в статус «Готовим эскиз» (ставится один раз)
  //  - sketchReadyAt   — момент ПЕРВОГО перехода в статус «Эскиз готов» (ставится один раз)
  sketchStartedAt       DateTime?
  sketchReadyAt         DateTime?
  // Лид (клиент из BlueSales), создавший заказ
  lead                  Lead?               @relation(fields: [leadId], references: [id])
  leadId                Int?
  // Подмодель с «сырыми» данными заказа из BlueSales (1-к-1)
  bluesalesInfo         BluesalesOrderInfo?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  dialogLink            String?

  @@index([source])
  @@index([leadId])
  @@index([deliveryManagerName])
  @@index([onboardingManagerName])
  @@index([sketchDesignerId])
  @@index([revisionDesignerId])
}

// Данные заказа, специфичные для BlueSales (1-к-1 с Order)
model BluesalesOrderInfo {
  id                    Int       @id @default(autoincrement())
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId               Int       @unique
  // id заказа в BlueSales — ключ идемпотентности импорта
  bsOrderId             Int       @unique
  // id клиента (customer.id) в BlueSales на момент синка заказа
  bsCustomerId          Int?
  bsNumber              String?
  // Статус заказа в BS (order.orderStatus)
  orderStatusId         Int?
  orderStatus           String?
  // Момент получения статуса от BlueSales. Защищает от применения устаревшего
  // ответа фонового синка после более нового пользовательского изменения.
  orderStatusObservedAt DateTime?
  // CRM-статус клиента/воронки (order.crmStatus), если есть
  crmStatusId           Int?
  crmStatus             String?
  totalSum              Float?
  prepaymentSum         Float?
  // Когда заказ создан в BlueSales (order.date)
  bsCreatedAt           DateTime?
  // Полный ответ BS на случай будущих полей / отладки
  rawPayload            Json?
  lastSyncedAt          DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([orderStatusId])
  @@index([crmStatusId])
  @@index([bsCustomerId])
  @@index([bsCreatedAt])
}

// Durable outbox исходящих изменений статуса. Одна строка содержит только
// конкретный переход, а не snapshot/полное тело заказа.
model OrderStatusChange {
  id             Int                    @id @default(autoincrement())
  order          Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        Int
  actor          User?                  @relation("OrderStatusChangeActor", fields: [actorId], references: [id])
  actorId        Int?
  fromStatusId   Int?
  fromStatusName String?
  toStatusId     Int
  toStatusName   String
  state          OrderStatusChangeState @default(PENDING)
  attempts       Int                    @default(0)
  nextAttemptAt  DateTime               @default(now())
  lockedAt       DateTime?
  leaseToken     String?
  lastError      String?
  createdAt      DateTime               @default(now())
  completedAt    DateTime?

  @@index([state, nextAttemptAt])
  @@index([orderId, state, id])
  @@index([actorId])
}

// Лид (клиент из BlueSales)
model Lead {
  id             Int       @id @default(autoincrement())
  // id клиента в BlueSales — ключ идемпотентности синка
  bsCustomerId   Int?      @unique
  name           String?
  fullName       String?
  // Менеджер клиента в BlueSales (customer.manager): имя и BS-id.
  // Денормализовано (не FK), т.к. это менеджер BlueSales, а не User системы.
  managerName    String?
  managerId      Int?
  // Ссылка на диалог в ВК-группе (переписка сообщество <-> лид)
  vkDialogUrl    String?
  vkUserId       String?
  // Дата первого контакта клиента в BlueSales
  firstContactAt DateTime?
  // Дата последнего контакта клиента в BlueSales — по ней refresh-loop лидов
  // отбирает «живых» лидов (аналог bsCreatedAt у заказов).
  lastContactAt  DateTime?
  // Источник клиента в BlueSales — ID (customer.source.id). Имя — в модели BluesalesSource.
  source         String?
  // Канал продаж клиента в BlueSales — ID (customer.salesChannel.id). Имя — в модели BluesalesSalesChannel.
  salesChannel   String?
  // Отметки клиента в BlueSales (поле shortNotes — простая строка)
  marks          String?
  // Теги клиента в BlueSales — список ID (tags[].id). Имена — в модели BluesalesTag.
  tags           String[]  @default([])
  crmStatus      String?
  orders         Order[]
  lastSyncedAt   DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([crmStatus])
  @@index([lastContactAt])
  @@index([managerId])
}

// Справочник тегов BlueSales: сопоставление ID тега -> имя.
// Намеренно без FK на Lead — это денормализованный lookup для отображения имён.
model BluesalesTag {
  // id тега в BlueSales (tags[].id)
  bsTagId   String   @id
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Справочник источников BlueSales: сопоставление ID источника -> имя (напр. "avito").
// Аналогично BluesalesTag — денормализованный lookup, без FK на Lead.
model BluesalesSource {
  // id источника в BlueSales (customer.source.id)
  bsSourceId String   @id
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Справочник каналов продаж BlueSales: сопоставление ID канала -> имя (напр. "ВКонтакте").
model BluesalesSalesChannel {
  // id канала продаж в BlueSales (customer.salesChannel.id)
  bsSalesChannelId String   @id
  name             String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Накопительный справочник статусов заказов BlueSales: сопоставление ID статуса -> имя.
// Пополняется при каждом чтении статусов из встреченных в заказах значений, поэтому
// статус остаётся доступным для установки, даже когда сейчас 0 заказов в этом статусе.
// Без FK на BluesalesOrderInfo — это денормализованный lookup.
model BluesalesOrderStatus {
  // id статуса заказа в BlueSales (order.orderStatus.id)
  bsOrderStatusId Int      @id
  name            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Chat {
  id          Int           @id @default(autoincrement())
  name        String
  type        ChatType      @default(PUBLIC)
  createdBy   User?         @relation("ChatCreatedBy", fields: [createdById], references: [id])
  createdById Int?
  members     ChatMember[]
  messages    ChatMessage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type])
  @@index([createdById])
}

model ChatMember {
  id        Int            @id @default(autoincrement())
  chat      Chat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  role      ChatMemberRole @default(MEMBER)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([chatId, userId])
  @@index([userId])
  @@index([chatId, createdAt])
}

model ChatMessage {
  id          Int          @id @default(autoincrement())
  chat        Chat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId      Int
  author      User         @relation(fields: [authorId], references: [id])
  authorId    Int
  body        String?
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([chatId, createdAt])
  @@index([authorId, createdAt])
}

model Message {
  id              Int              @id @default(autoincrement())
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         Int
  author          User             @relation(fields: [authorId], references: [id])
  authorId        Int
  body            String?
  // Тип сообщения теперь выводится из связей, а не хранится в колонке kind:
  //  - есть revision            -> это ЗАПРОС правки (REVISION_REQUEST)
  //  - есть revisionClosure     -> это ОТВЕТ/закрытие правки (REVISION_ANSWER)
  //  - нет ни того ни другого   -> обычное сообщение (NORMAL)
  revision        Revision?        @relation("RevisionRequestMessage")
  revisionClosure RevisionClosure? @relation("RevisionClosureMessage")
  attachments     Attachment[]
  createdAt       DateTime         @default(now())

  @@index([orderId, createdAt])
}

// Запрос на правку. Намеренно «пустая» модель — для аналитики важен сам факт
// правки, а не кто её открыл (это видно через связанное сообщение при желании).
model Revision {
  id        Int              @id @default(autoincrement())
  order     Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   Int
  // 1-к-1 с сообщением-запросом
  message   Message          @relation("RevisionRequestMessage", fields: [messageId], references: [id], onDelete: Cascade)
  messageId Int              @unique
  openedAt  DateTime         @default(now())
  // 1-к-1 закрытие (если правка закрыта)
  closure   RevisionClosure?
  createdAt DateTime         @default(now())

  @@index([orderId])
}

// Закрытие правки. С денормализацией под аналитику: кто закрыл + когда открыта/закрыта.
model RevisionClosure {
  id         Int      @id @default(autoincrement())
  // 1-к-1 с правкой
  revision   Revision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId Int      @unique
  // 1-к-1 с сообщением-ответом (может отсутствовать, если сообщение удалят)
  message    Message? @relation("RevisionClosureMessage", fields: [messageId], references: [id], onDelete: SetNull)
  messageId  Int?     @unique
  // Денормализовано: художник правок, закрывший правку
  closedBy   User     @relation("RevisionClosedBy", fields: [closedById], references: [id])
  closedById Int
  // Денормализовано под аналитику: время открытия (дублирует Revision.openedAt) и закрытия
  openedAt   DateTime
  closedAt   DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([closedById])
  @@index([closedAt])
}

// Лог событий по заказу: аудит ручных изменений полей в нашем CRM
// («кто и что с чего на что поменял»). Отображается системными плашками
// в чате заказа. actor = null зарезервировано под системные события
// (напр. изменения, прилетевшие из синка BlueSales) на будущее.
model OrderEvent {
  id        Int      @id @default(autoincrement())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   Int
  // Автор изменения. null = системное событие (не пользователь).
  actor     User?    @relation("OrderEventActor", fields: [actorId], references: [id])
  actorId   Int?
  // Стабильный ключ поля: sketchDesigner | revisionDesigner | orderStatus |
  // crmStatus | orderNumber | title | dialogLink. Человекочитаемую подпись
  // формирует фронтенд.
  field     String
  // Значения в человекочитаемом виде (имена художников/статусов, текст).
  oldValue  String?
  newValue  String?
  // Доп. данные (напр. { oldId, newId } для статусов/художников).
  meta      Json?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([actorId])
}

model Attachment {
  id            Int          @id @default(autoincrement())
  message       Message?     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId     Int?
  chatMessage   ChatMessage? @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)
  chatMessageId Int?
  objectKey     String
  filename      String
  mimeType      String?
  kind          String       @default("attachment")
  createdAt     DateTime     @default(now())

  @@index([messageId])
  @@index([chatMessageId])
}
